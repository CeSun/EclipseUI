@using Eclipse.Controls

<StackPanel Orientation="Horizontal" Spacing="10" BackgroundColor="#FFFFFF" Padding="15">
    <Label Text=@Title FontSize="18" FontWeight="Bold" Color="#333" />
    @if (!string.IsNullOrEmpty(Subtitle))
    {
        <Label Text=@Subtitle FontSize="12" Color="#666" />
    }
</StackPanel>

@code {
    public string? Title { get; set; }
    public string? Subtitle { get; set; }
}