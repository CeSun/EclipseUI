<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>Eclipse.Demo</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- 生成源码文件到磁盘以便调试 -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(BaseIntermediateOutputPath)Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Eclipse.Core\Eclipse.Core.csproj" />
    <ProjectReference Include="..\..\src\Eclipse.Controls\Eclipse.Controls.csproj" />
    <ProjectReference Include="..\..\src\Eclipse.Skia\Eclipse.Skia.csproj" />
    <ProjectReference Include="..\..\src\Eclipse.Windows\Eclipse.Windows.csproj" />
  </ItemGroup>

  <!-- Source Generator -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\Eclipse.Generator\Eclipse.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- EUI 文件 -->
  <ItemGroup>
    <AdditionalFiles Include="Components\**\*.eui" />
  </ItemGroup>
</Project>