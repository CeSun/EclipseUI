@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="👋 欢迎使用 EclipseUI Demo！" FontSize="24" FontWeight="true" />
    <TextBlock Text="使用底部导航栏切换不同的控件测试页面。" FontSize="16" PaddingBottom="10" />
    
    <TextBlock Text="📦 已实现控件：" FontSize="18" FontWeight="true" PaddingBottom="10" />
    
    <StackPanel Spacing="8">
        <TextBlock Text="✅ TextBox - 文本输入框" FontSize="14" />
        <TextBlock Text="✅ ComboBox - 下拉选择框" FontSize="14" />
        <TextBlock Text="✅ CheckBox - 复选框（支持三态）" FontSize="14" />
        <TextBlock Text="✅ RadioButton - 单选框（分组互斥）" FontSize="14" />
        <TextBlock Text="✅ ToggleSwitch - 开关控件" FontSize="14" />
        <TextBlock Text="✅ Slider - 滑块（水平/垂直/刻度）" FontSize="14" />
    </StackPanel>
    
    <TextBlock Text="🔧 布局控件：" FontSize="18" FontWeight="true" PaddingTop="20" PaddingBottom="10" />
    
    <StackPanel Spacing="8">
        <TextBlock Text="✅ StackPanel - 堆叠布局" FontSize="14" />
        <TextBlock Text="✅ Grid - 网格布局" FontSize="14" />
        <TextBlock Text="✅ DockPanel - 停靠布局" FontSize="14" />
        <TextBlock Text="✅ ScrollView - 滚动容器" FontSize="14" />
    </StackPanel>
    
    <TextBlock Text="🧪 测试页面：" FontSize="18" FontWeight="true" PaddingTop="20" PaddingBottom="10" />
    
    <StackPanel Spacing="8">
        <TextBlock Text="🔍 布局自适应测试 - 验证窗口拉伸时的自适应效果" FontSize="14" />
    </StackPanel>
</StackPanel>