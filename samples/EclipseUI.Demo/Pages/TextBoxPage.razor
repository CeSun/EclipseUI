@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="📝 TextBox 文本输入" FontSize="24" FontWeight="true" />
    
    <TextBlock Text="基础输入：" FontSize="16" PaddingBottom="5" />
    <TextBox @bind-Text="_textBoxValue" Placeholder="请输入文本..." Width="300" />
    <TextBlock Text="@($"当前值：{_textBoxValue}")" FontSize="12" PaddingBottom="15" />
    
    <TextBlock Text="带占位符：" FontSize="16" PaddingBottom="5" />
    <TextBox @bind-Text="_username" Placeholder="请输入用户名..." Width="300" />
    <TextBlock Text="@($"用户名：{_username}")" FontSize="12" PaddingBottom="15" />
    
    <TextBlock Text="不同尺寸：" FontSize="16" PaddingBottom="5" />
    <StackPanel Spacing="10">
        <TextBox @bind-Text="_text200" Placeholder="宽度 200" Width="200" />
        <TextBox @bind-Text="_text350" Placeholder="宽度 350" Width="350" />
        <TextBox @bind-Text="_text400" Placeholder="宽度 400" Width="400" />
    </StackPanel>
    <TextBlock Text="@($"输入内容：{_text200} | {_text350} | {_text400}")" FontSize="12" />
</StackPanel>

@code {
    private string _textBoxValue = "";
    private string _username = "";
    private string _text200 = "";
    private string _text350 = "";
    private string _text400 = "";
}
