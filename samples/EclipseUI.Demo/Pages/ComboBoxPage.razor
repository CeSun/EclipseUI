@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="🔽 ComboBox 下拉选择" FontSize="24" FontWeight="true" />
    
    <TextBlock Text="使用 ItemsSource：" FontSize="16" PaddingBottom="5" />
    <ComboBox ItemsSource="@_comboBoxItems" @bind-SelectedItem="_comboBoxSelected" Placeholder="请选择..." Width="250" />
    <TextBlock Text="@($"当前选择：{_comboBoxSelected ?? "无"}")" FontSize="12" PaddingBottom="20" />
    
    <TextBlock Text="使用 ComboBoxItem 子组件：" FontSize="16" PaddingBottom="5" />
    <ComboBox @bind-SelectedItem="_selectedFruit" Placeholder="选择水果..." Width="250">
        <ComboBoxItem Value="apple" Text="🍎 苹果" />
        <ComboBoxItem Value="banana" Text="🍌 香蕉" />
        <ComboBoxItem Value="orange" Text="🍊 橙子" />
        <ComboBoxItem Value="grape" Text="🍇 葡萄" />
        <ComboBoxItem Value="strawberry" Text="🍓 草莓" />
    </ComboBox>
    <TextBlock Text="@($"选中值：{_selectedFruit ?? "无"}")" FontSize="12" PaddingBottom="20" />
    
    <TextBlock Text="带初始值的下拉框：" FontSize="16" PaddingBottom="5" />
    <ComboBox @bind-SelectedItem="_selectedColor" Placeholder="选择颜色..." Width="250">
        <ComboBoxItem Value="red" Text="🔴 红色" />
        <ComboBoxItem Value="green" Text="🟢 绿色" />
        <ComboBoxItem Value="blue" Text="🔵 蓝色" />
        <ComboBoxItem Value="yellow" Text="🟡 黄色" />
        <ComboBoxItem Value="purple" Text="🟣 紫色" />
    </ComboBox>
    <TextBlock Text="@($"选中值：{_selectedColor ?? "无"}")" FontSize="12" />
</StackPanel>

@code {
    private List<string> _comboBoxItems = new() { "选项一", "选项二", "选项三", "选项四", "选项五" };
    private string? _comboBoxSelected;
    private string? _selectedFruit;
    private string? _selectedColor;
}
