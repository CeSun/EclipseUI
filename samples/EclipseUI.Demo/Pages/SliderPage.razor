@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="📊 Slider 滑块" FontSize="24" FontWeight="true" />
    
    <TextBlock Text="音量控制：" FontSize="16" PaddingBottom="5" />
    <Slider @bind-Value="_slider1" Minimum="0" Maximum="100" Width="300" />
    <TextBlock Text="@($"音量：{(int)_slider1}")" FontSize="12" PaddingBottom="20" />
    
    <TextBlock Text="亮度（带刻度）：" FontSize="16" PaddingBottom="5" />
    <Slider @bind-Value="_slider2" Minimum="0" Maximum="100" Width="300" ShowTicks="true" TickFrequency="10" IsSnapToTick="true" />
    <TextBlock Text="@($"亮度：{(int)_slider2}")" FontSize="12" PaddingBottom="20" />
    
    <TextBlock Text="温度调节：" FontSize="16" PaddingBottom="5" />
    <Slider @bind-Value="_slider3" Minimum="16" Maximum="30" Width="300" ShowTicks="true" TickFrequency="2" />
    <TextBlock Text="@($"温度：{_slider3}°C")" FontSize="12" PaddingBottom="20" />
    
    <TextBlock Text="进度滑块：" FontSize="16" PaddingBottom="5" />
    <Slider @bind-Value="_slider4" Minimum="0" Maximum="100" Width="300" />
    <TextBlock Text="@($"进度：{(int)_slider4}%")" FontSize="12" />
</StackPanel>

@code {
    private double _slider1 = 50;
    private double _slider2 = 75;
    private double _slider3 = 22;
    private double _slider4 = 30;
}
