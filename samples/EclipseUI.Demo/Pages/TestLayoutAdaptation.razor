@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="🔍 布局自适应测试页面" FontSize="24" FontWeight="true" />
    
    <TextBlock Text="以下是测试窗口拉伸自适应的布局组件：" FontSize="16" />
    
    <!-- 垂直堆叠面板测试 -->
    <TextBlock Text="1. StackPanel 垂直布局测试：" FontSize="18" FontWeight="true" />
    <StackPanel Orientation="StackOrientation.Vertical" Spacing="10" Background="#f0f0f0" PaddingLeft="10" PaddingRight="10" PaddingTop="10" PaddingBottom="10">
        <Button Text="拉伸按钮 1 (HorizontalAlignment.Stretch)" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Button Text="拉伸按钮 2 (HorizontalAlignment.Stretch)" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Button Text="普通按钮 (HorizontalAlignment.Left)" HorizontalAlignment="HorizontalAlignment.Left" />
        <TextBlock Text="拉伸文本块 (HorizontalAlignment.Stretch)" HorizontalAlignment="HorizontalAlignment.Stretch" Background="#e0e0e0" PaddingLeft="5" PaddingRight="5" PaddingTop="5" PaddingBottom="5"/>
    </StackPanel>
    
    <!-- 水平堆叠面板测试 -->
    <TextBlock Text="2. StackPanel 水平布局测试：" FontSize="18" FontWeight="true" />
    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10" Background="#f0f0f0" PaddingLeft="10" PaddingRight="10" PaddingTop="10" PaddingBottom="10">
        <Button Text="按钮 1" HorizontalAlignment="HorizontalAlignment.Stretch" Width="100" />
        <Button Text="按钮 2" HorizontalAlignment="HorizontalAlignment.Stretch" Width="100" />
        <Button Text="按钮 3" HorizontalAlignment="HorizontalAlignment.Stretch" Width="100" />
    </StackPanel>
    
    <!-- 网格布局测试 -->
    <TextBlock Text="3. Grid 布局测试：" FontSize="18" FontWeight="true" />
    <Grid RowDefinitions="Auto, *" ColumnDefinitions="*, 2*" Spacing="10" Background="#f0f0f0" PaddingLeft="10" PaddingRight="10" PaddingTop="10" PaddingBottom="10">
        <TextBlock Text="标题行 (跨越两列)" Grid.ColumnSpan="2" HorizontalAlignment="HorizontalAlignment.Center" Background="#d0d0d0" />
        <Button Text="左列按钮" Grid.Row="1" Grid.Column="0" HorizontalAlignment="HorizontalAlignment.Stretch" VerticalAlignment="VerticalAlignment.Stretch" />
        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5" Background="#e8e8e8" PaddingLeft="5" PaddingRight="5" PaddingTop="5" PaddingBottom="5">
            <TextBlock Text="右列内容区域" HorizontalAlignment="HorizontalAlignment.Center" />
            <Button Text="右列按钮 1" HorizontalAlignment="HorizontalAlignment.Stretch" />
            <Button Text="右列按钮 2" HorizontalAlignment="HorizontalAlignment.Stretch" />
        </StackPanel>
    </Grid>
    
    <!-- DockPanel 测试 -->
    <TextBlock Text="4. DockPanel 布局测试：" FontSize="18" FontWeight="true" />
    <DockPanel LastChildFill="true" Background="#f0f0f0" PaddingLeft="10" PaddingRight="10" PaddingTop="10" PaddingBottom="10" Height="150">
        <DockPanelItem Dock="Dock.Top">
            <TextBlock Text="顶部区域" HorizontalAlignment="HorizontalAlignment.Center" Background="#c0c0c0" PaddingLeft="5" PaddingRight="5" PaddingTop="5" PaddingBottom="5"/>
        </DockPanelItem>
        <DockPanelItem Dock="Dock.Bottom">
            <TextBlock Text="底部区域" HorizontalAlignment="HorizontalAlignment.Center" Background="#c0c0c0" PaddingLeft="5" PaddingRight="5" PaddingTop="5" PaddingBottom="5"/>
        </DockPanelItem>
        <DockPanelItem Dock="Dock.Left">
            <Button Text="左侧按钮" HorizontalAlignment="HorizontalAlignment.Stretch" VerticalAlignment="VerticalAlignment.Stretch" />
        </DockPanelItem>
        <DockPanelItem Dock="Dock.Right">
            <Button Text="右侧按钮" HorizontalAlignment="HorizontalAlignment.Stretch" VerticalAlignment="VerticalAlignment.Stretch" />
        </DockPanelItem>
        <DockPanelItem>
            <TextBlock Text="中央区域 (填充剩余空间)" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Background="#d0d0d0" />
        </DockPanelItem>
    </DockPanel>
</StackPanel>