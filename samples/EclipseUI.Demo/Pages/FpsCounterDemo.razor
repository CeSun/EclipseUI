@page "/fps-counter"
@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<FpsCounter IsVisible="true" Color="#FF0000" FontSize="14" X="10" Y="10" />

<Border Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Width="300" Height="200">
    <StackPanel Orientation="StackOrientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center">
        <TextBlock Text="FPS Counter Demo" FontSize="18" Margin="0,0,0,20" />
        <Button Text="Test Button" OnClick="OnButtonClick" />
        <TextBlock Text="@buttonClickCount.ToString()" Margin="0,10,0,0" />
    </StackPanel>
</Border>

@code {
    private int buttonClickCount = 0;
    
    private void OnButtonClick()
    {
        buttonClickCount++;
    }
}