@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Spacing="20">
    <TextBlock Text="🎨 Border / Image / ProgressBar" FontSize="24" FontWeight="true" />
    
    <!-- Border 示例 -->
    <TextBlock Text="Border 边框容器：" FontSize="16" PaddingBottom="5" />
    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
        <Border Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="2" CornerRadius="8" PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
            <TextBlock Text="蓝色边框" FontSize="14" />
        </Border>
        <Border Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="2" CornerRadius="12" PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
            <TextBlock Text="橙色圆角" FontSize="14" />
        </Border>
        <Border Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="3" CornerRadius="0" PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
            <TextBlock Text="绿色直角" FontSize="14" />
        </Border>
    </StackPanel>
    
    <!-- ProgressBar 示例 -->
    <TextBlock Text="ProgressBar 进度条：" FontSize="16" PaddingTop="15" PaddingBottom="5" />
    <StackPanel Spacing="15">
        <StackPanel Spacing="5">
            <TextBlock Text="@($"进度：{(int)_progress}%")" FontSize="12" />
            <ProgressBar Value="@_progress" Width="300" Height="8" />
        </StackPanel>
        
        <StackPanel Spacing="5">
            <TextBlock Text="自定义颜色：" FontSize="12" />
            <ProgressBar Value="75" Foreground="#4CAF50" Background="#E8F5E9" Width="300" Height="10" CornerRadius="5" />
        </StackPanel>
        
        <StackPanel Spacing="5">
            <TextBlock Text="细进度条：" FontSize="12" />
            <ProgressBar Value="60" Foreground="#FF9800" Width="300" Height="4" CornerRadius="2" />
        </StackPanel>
        
        <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10">
            <Button Text="增加" Width="80" Height="32" OnClick="IncreaseProgress" />
            <Button Text="减少" Width="80" Height="32" OnClick="DecreaseProgress" />
            <Button Text="重置" Width="80" Height="32" OnClick="ResetProgress" />
        </StackPanel>
    </StackPanel>
    
    <!-- Image 示例 -->
    <TextBlock Text="Image 图片：" FontSize="16" PaddingTop="15" PaddingBottom="5" />
    <StackPanel Spacing="10">
        <TextBlock Text="不同 Stretch 模式：" FontSize="12" />
        <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
            <StackPanel Spacing="5">
                <TextBlock Text="Uniform" FontSize="10" />
                <Border BorderBrush="#E0E0E0" BorderThickness="1" Width="120" Height="80">
                    <Image Source="@_imagePath" Width="120" Height="80" Stretch="Stretch.Uniform" />
                </Border>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="Fill" FontSize="10" />
                <Border BorderBrush="#E0E0E0" BorderThickness="1" Width="120" Height="80">
                    <Image Source="@_imagePath" Width="120" Height="80" Stretch="Stretch.Fill" />
                </Border>
            </StackPanel>
            <StackPanel Spacing="5">
                <TextBlock Text="UniformToFill" FontSize="10" />
                <Border BorderBrush="#E0E0E0" BorderThickness="1" Width="120" Height="80">
                    <Image Source="@_imagePath" Width="120" Height="80" Stretch="Stretch.UniformToFill" />
                </Border>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</StackPanel>

@code {
    private double _progress = 50;
    private string _imagePath = Path.Combine(AppContext.BaseDirectory, "Assets", "sample.png");
    
    private void IncreaseProgress()
    {
        _progress = Math.Min(100, _progress + 10);
    }
    
    private void DecreaseProgress()
    {
        _progress = Math.Max(0, _progress - 10);
    }
    
    private void ResetProgress()
    {
        _progress = 0;
    }
}
