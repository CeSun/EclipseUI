@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core
@using EclipseUI.Demo.Pages

<Grid RowDefinitions="Auto, *" Spacing="0">
    <!-- 顶部标题栏 -->
    <GridItem Row="0" Background="#1976D2">
        <Grid RowDefinitions="Auto, Auto" PaddingLeft="15" PaddingTop="10" PaddingRight="15" PaddingBottom="10">
            <GridItem Row="0">
                <TextBlock Text="🌑 EclipseUI Demo" FontSize="24" FontWeight="true" Foreground="#FFFFFF" />
            </GridItem>
            <GridItem Row="1" PaddingTop="5">
                <TextBlock Text="@_pageTitle" FontSize="14" Foreground="#B3E5FC" />
            </GridItem>
        </Grid>
    </GridItem>
    
    <!-- 主内容区 -->
    <GridItem Row="1">
        <Grid RowDefinitions="*, Auto" Spacing="0">
            <!-- 页面内容 -->
            <GridItem Row="0">
                <ScrollView PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20">
                    @{
                        // 使用独立变量来确保页面切换的原子性
                        var currentPage = _currentPage;
                        switch (currentPage)
                        {
                            case 0:
                                <HomePage />
                                break;
                            case 1:
                                <TextBoxPage />
                                break;
                            case 2:
                                <ComboBoxPage />
                                break;
                            case 3:
                                <CheckBoxPage />
                                break;
                            case 4:
                                <RadioButtonPage />
                                break;
                            case 5:
                                <ToggleSwitchPage />
                                break;
                            case 6:
                                <SliderPage />
                                break;
                            case 7:
                                <TestLayoutAdaptation />
                                break;
                            case 8:
                                <ControlsPage />
                                break;
                        }
                    }
                </ScrollView>
            </GridItem>
            
            <!-- 底部导航栏 -->
            <GridItem Row="1" Background="#F5F5F5">
                <ScrollView Orientation="ScrollOrientation.Horizontal" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="16">
                    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="5">
                        <Button Text="🏠 主页" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToMain" />
                        <Button Text="📝 TextBox" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToTextBox" />
                        <Button Text="🔽 ComboBox" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToComboBox" />
                        <Button Text="☑️ CheckBox" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToCheckBox" />
                        <Button Text="🔘 Radio" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToRadioButton" />
                        <Button Text="🔛 Toggle" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToToggleSwitch" />
                        <Button Text="📊 Slider" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToSlider" />
                        <Button Text="🔍 布局测试" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToLayoutTest" />
                        <Button Text="🎨 更多控件" Width="90" Height="36" Background="#E0E0E0" OnClick="GoToControls" />
                    </StackPanel>
                </ScrollView>
            </GridItem>
        </Grid>
    </GridItem>
</Grid>

@code {
    private int _currentPage = 0;
    private string _pageTitle = "主页面";
    
    // 导航方法
    private void GoToMain(MouseEventArgs e) { UpdatePage(0, "主页面"); }
    private void GoToTextBox(MouseEventArgs e) { UpdatePage(1, "TextBox 测试"); }
    private void GoToComboBox(MouseEventArgs e) { UpdatePage(2, "ComboBox 测试"); }
    private void GoToCheckBox(MouseEventArgs e) { UpdatePage(3, "CheckBox 测试"); }
    private void GoToRadioButton(MouseEventArgs e) { UpdatePage(4, "RadioButton 测试"); }
    private void GoToToggleSwitch(MouseEventArgs e) { UpdatePage(5, "ToggleSwitch 测试"); }
    private void GoToSlider(MouseEventArgs e) { UpdatePage(6, "Slider 测试"); }
    private void GoToLayoutTest(MouseEventArgs e) { UpdatePage(7, "布局自适应测试"); }
    private void GoToControls(MouseEventArgs e) { UpdatePage(8, "Border / Image / ProgressBar"); }
    
    private void UpdatePage(int newPage, string title)
    {
        // 确保页面切换的原子性
        _currentPage = newPage;
        _pageTitle = title;
        
        // 强制重新渲染，确保旧页面完全清除
        StateHasChanged();
    }
}
