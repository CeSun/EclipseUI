@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<ScrollView PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20">
    <StackPanel Spacing="15">
        <!-- 标题 -->
        <TextBlock Text="🌑 EclipseUI 完整控件测试" FontSize="28" FontWeight="true" PaddingBottom="10" />
        
        <!-- TextBox 测试页面链接 -->
        <Grid ColumnDefinitions="Auto, *" Spacing="10" Background="#E3F2FD" PaddingLeft="15" PaddingTop="12" PaddingRight="15" PaddingBottom="12">
            <GridItem Column="0" VerticalAlignment="VerticalAlignment.Center">
                <TextBlock Text="📝 TextBox 控件已实现！" FontSize="16" FontWeight="true" />
            </GridItem>
            <GridItem Column="1" HorizontalAlignment="HorizontalAlignment.Right">
                <Button Text="查看 TextBox 测试页面" Background="#2196F3" OnClick="NavigateToTextBoxTest" />
            </GridItem>
        </Grid>
        
        <!-- ==================== 1. 固定尺寸测试 ==================== -->
        <TextBlock Text="📏 1. 固定尺寸 (Width/Height)" FontSize="18" FontWeight="true" Background="#E3F2FD" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
            <Button Text="100×40" Width="100" Height="40" Background="#2196F3" />
            <Button Text="150×50" Width="150" Height="50" Background="#4CAF50" />
            <Button Text="200×60" Width="200" Height="60" Background="#FF9800" />
        </StackPanel>
        
        <!-- ==================== 2. 最小尺寸测试 ==================== -->
        <TextBlock Text="📐 2. 最小尺寸 (MinWidth/MinHeight)" FontSize="18" FontWeight="true" Background="#E8F5E9" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
            <Button Text="MinW=120" MinWidth="120" Background="#9C27B0" />
            <Button Text="MinW=150" MinWidth="150" Background="#E91E63" />
            <Button Text="MinH=60" MinHeight="60" Background="#00BCD4" />
        </StackPanel>
        
        <!-- ==================== 3. 最大尺寸测试 ==================== -->
        <TextBlock Text="📏 3. 最大尺寸 (MaxWidth/MaxHeight)" FontSize="18" FontWeight="true" Background="#FFF3E0" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <Button Text="MaxWidth=200" MaxWidth="200" Background="#FFC107" HorizontalAlignment="HorizontalAlignment.Left" />
            <TextBlock Text="这是一个设置了 MaxWidth=250 的文本块，当文本内容超过最大宽度时会自动换行。这是第二行文字，继续测试换行功能是否正常工作。如果看到多行文本说明换行功能正常！" MaxWidth="250" Background="#FFCCBC" PaddingLeft="10" PaddingTop="10" PaddingRight="10" PaddingBottom="10" />
        </StackPanel>
        
        <!-- ==================== 4. 水平对齐测试 ==================== -->
        <TextBlock Text="📍 4. 水平对齐 (HorizontalAlignment)" FontSize="18" FontWeight="true" Background="#F3E5F5" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <Button Text="Left (左对齐)" Width="200" HorizontalAlignment="HorizontalAlignment.Left" Background="#3F51B5" />
            <Button Text="Center (居中对齐)" Width="200" HorizontalAlignment="HorizontalAlignment.Center" Background="#673AB7" />
            <Button Text="Right (右对齐)" Width="200" HorizontalAlignment="HorizontalAlignment.Right" Background="#9C27B0" />
            <Button Text="Stretch (拉伸填满)" HorizontalAlignment="HorizontalAlignment.Stretch" Background="#E91E63" />
        </StackPanel>
        
        <!-- ==================== 5. 垂直对齐测试 ==================== -->
        <TextBlock Text="⬆️ 5. 垂直对齐 (VerticalAlignment)" FontSize="18" FontWeight="true" Background="#FFEBEE" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Grid RowDefinitions="60, 60" ColumnDefinitions="*, *, *, *" Spacing="5" Background="#FFF0F0">
            <GridItem Row="0" Column="0" Background="#FFEBEE" VerticalAlignment="VerticalAlignment.Top"><Button Text="Top" Background="#F44336" /></GridItem>
            <GridItem Row="0" Column="1" Background="#E8F5E9" VerticalAlignment="VerticalAlignment.Center"><Button Text="Center" Background="#4CAF50" /></GridItem>
            <GridItem Row="0" Column="2" Background="#FFF8E1" VerticalAlignment="VerticalAlignment.Bottom"><Button Text="Bottom" Background="#FFC107" /></GridItem>
            <GridItem Row="0" Column="3" Background="#E3F2FD" VerticalAlignment="VerticalAlignment.Stretch"><Button Text="Stretch" Background="#2196F3" /></GridItem>
            <GridItem Row="1" Column="0" Background="#F3E5F5" VerticalAlignment="VerticalAlignment.Top" HorizontalAlignment="HorizontalAlignment.Left"><TextBlock Text="↖" Background="#9C27B0" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" /></GridItem>
            <GridItem Row="1" Column="1" Background="#E0F7FA" VerticalAlignment="VerticalAlignment.Bottom" HorizontalAlignment="HorizontalAlignment.Right"><TextBlock Text="↘" Background="#00BCD4" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" /></GridItem>
            <GridItem Row="1" Column="2" Background="#FFFDE7" VerticalAlignment="VerticalAlignment.Top" HorizontalAlignment="HorizontalAlignment.Left"><TextBlock Text="↖" Background="#FFEB3B" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" /></GridItem>
            <GridItem Row="1" Column="3" Background="#EFEBE9" VerticalAlignment="VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.Center"><TextBlock Text="居中" Background="#795548" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" /></GridItem>
        </Grid>
        
        <!-- ==================== 6. 组合使用测试 ==================== -->
        <TextBlock Text="🔧 6. 组合使用 (Width + Alignment + Min/Max)" FontSize="18" FontWeight="true" Background="#E8EAF6" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Grid ColumnDefinitions="*, *" Spacing="15" Background="#F0F0FF">
            <GridItem Column="0" Background="#E8EAF6" HorizontalAlignment="HorizontalAlignment.Center">
                <StackPanel PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" Spacing="10">
                    <TextBlock Text="Width + Center" FontSize="14" />
                    <Button Text="Width=180 + Center" Width="180" MinHeight="50" Background="#3F51B5" />
                </StackPanel>
            </GridItem>
            <GridItem Column="1" Background="#E8F5E9" HorizontalAlignment="HorizontalAlignment.Right">
                <StackPanel PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15" Spacing="10">
                    <TextBlock Text="Min/Max + Right" FontSize="14" />
                    <Button Text="Min100 Max250 + Right" MinWidth="100" MaxWidth="250" Background="#4CAF50" />
                </StackPanel>
            </GridItem>
        </Grid>
        
        <!-- ==================== 7. Grid 布局测试 ==================== -->
        <TextBlock Text="📐 7. Grid 网格布局" FontSize="18" FontWeight="true" Background="#E0F2F1" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="150, *, 150" Spacing="10">
            <!-- 顶部标题 -->
            <GridItem Row="0" Column="0" ColumnSpan="3" Background="#2196F3">
                <StackPanel PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
                    <TextBlock Text="Grid 布局演示" FontSize="20" FontWeight="true" />
                </StackPanel>
            </GridItem>
            <!-- 左侧导航 -->
            <GridItem Row="1" Column="0" Background="#4CAF50">
                <StackPanel Orientation="StackOrientation.Vertical" Spacing="10" PaddingLeft="15" PaddingTop="20" PaddingRight="15" PaddingBottom="20">
                    <TextBlock Text="🧭 导航" FontSize="16" FontWeight="true" />
                    <Button Text="🏠 首页" />
                    <Button Text="⚙️ 设置" />
                    <Button Text="ℹ️ 关于" />
                </StackPanel>
            </GridItem>
            <!-- 中间内容 -->
            <GridItem Row="1" Column="1" Background="#9C27B0">
                <StackPanel Orientation="StackOrientation.Vertical" Spacing="15" PaddingLeft="30" PaddingTop="30" PaddingRight="30" PaddingBottom="30">
                    <TextBlock Text="欢迎使用 Grid 布局！" FontSize="20" FontWeight="true" />
                    <TextBlock Text="这是一个 3 行 3 列的网格：\n• 第 1 行：Auto 高度（标题）\n• 第 2 行：* 比例高度（内容区）\n• 第 3 行：Auto 高度（状态栏）\n• 第 1 列：150px 固定宽度\n• 第 2 列：* 比例宽度\n• 第 3 列：150px 固定宽度" FontSize="14" />
                    <Button Text="点击测试" Background="#FF5722" FontSize="16" />
                </StackPanel>
            </GridItem>
            <!-- 右侧工具 -->
            <GridItem Row="1" Column="2" Background="#FF9800">
                <StackPanel Orientation="StackOrientation.Vertical" Spacing="10" PaddingLeft="15" PaddingTop="20" PaddingRight="15" PaddingBottom="20">
                    <TextBlock Text="🛠️ 工具" FontSize="16" FontWeight="true" />
                    <Button Text="📝 编辑" />
                    <Button Text="🗑️ 删除" />
                    <Button Text="💾 保存" />
                </StackPanel>
            </GridItem>
        </Grid>
        
        <!-- ==================== 8. ScrollView 滚动测试 ==================== -->
        <TextBlock Text="📜 8. ScrollView 滚动测试" FontSize="18" FontWeight="true" Background="#FFF8E1" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <TextBlock Text="提示：使用鼠标滚轮滚动，或拖动右侧滚动条，或点击滚动条空白区域快速滚动" Background="#FFF3E0" PaddingLeft="10" PaddingTop="10" PaddingRight="10" PaddingBottom="10" />
        
        <!-- ==================== 状态栏 ==================== -->
        <TextBlock Text="✅ 已完整支持：Width/Height | MinWidth/MinHeight | MaxWidth/MaxHeight | HorizontalAlignment | VerticalAlignment | Padding | Grid Spacing | 文本自动换行 | ScrollView 滚动" FontSize="13" Background="#ECEFF1" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="12" />
    </StackPanel>
</ScrollView>

