@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20" Spacing="10">
    <!-- 标题 -->
    <TextBlock Text="EclipseUI - Layout Test" FontSize="24" FontWeight="true" />
    
    <!-- 固定尺寸 -->
    <TextBlock Text="Width/Height" FontSize="16" FontWeight="true" />
    <Grid ColumnDefinitions="*, *, *" Spacing="10">
        <GridItem Column="0"><Button Text="100x40" Width="100" Height="40" Background="#2196F3" /></GridItem>
        <GridItem Column="1"><Button Text="150x50" Width="150" Height="50" Background="#4CAF50" /></GridItem>
        <GridItem Column="2"><Button Text="200x60" Width="200" Height="60" Background="#FF9800" /></GridItem>
    </Grid>
    
    <!-- 最小尺寸 -->
    <TextBlock Text="MinWidth/MinHeight" FontSize="16" FontWeight="true" />
    <Grid ColumnDefinitions="*, *, *" Spacing="10">
        <GridItem Column="0"><Button Text="MinWidth=120" MinWidth="120" Background="#9C27B0" /></GridItem>
        <GridItem Column="1"><Button Text="MinWidth=150" MinWidth="150" Background="#E91E63" /></GridItem>
        <GridItem Column="2"><Button Text="MinHeight=60" MinHeight="60" Background="#00BCD4" /></GridItem>
    </Grid>
    
    <!-- 最大尺寸 -->
    <TextBlock Text="MaxWidth/MaxHeight" FontSize="16" FontWeight="true" />
    <Grid ColumnDefinitions="*, *" Spacing="10">
        <GridItem Column="0"><Button Text="MaxWidth=150" MaxWidth="150" Background="#FFC107" /></GridItem>
        <GridItem Column="1"><Button Text="MaxHeight=80" MaxHeight="80" Background="#FF5722" /></GridItem>
    </Grid>
    
    <!-- 水平对齐 -->
    <TextBlock Text="HorizontalAlignment" FontSize="16" FontWeight="true" />
    <StackPanel Spacing="8">
        <Button Text="Left" HorizontalAlignment="HorizontalAlignment.Left" Background="#3F51B5" />
        <Button Text="Center" HorizontalAlignment="HorizontalAlignment.Center" Background="#673AB7" />
        <Button Text="Right" HorizontalAlignment="HorizontalAlignment.Right" Background="#9C27B0" />
        <Button Text="Stretch" HorizontalAlignment="HorizontalAlignment.Stretch" Background="#E91E63" />
    </StackPanel>
    
    <!-- 垂直对齐 -->
    <TextBlock Text="VerticalAlignment" FontSize="16" FontWeight="true" />
    <Grid RowDefinitions="60, 60" ColumnDefinitions="*, *, *, *" Spacing="5">
        <GridItem Row="0" Column="0" Background="#FFEBEE"><Button Text="Top" VerticalAlignment="VerticalAlignment.Top" Background="#F44336" /></GridItem>
        <GridItem Row="0" Column="1" Background="#E8F5E9"><Button Text="Center" VerticalAlignment="VerticalAlignment.Center" Background="#4CAF50" /></GridItem>
        <GridItem Row="0" Column="2" Background="#FFF8E1"><Button Text="Bottom" VerticalAlignment="VerticalAlignment.Bottom" Background="#FFC107" /></GridItem>
        <GridItem Row="0" Column="3" Background="#E3F2FD"><Button Text="Stretch" VerticalAlignment="VerticalAlignment.Stretch" Background="#2196F3" /></GridItem>
    </Grid>
    
    <!-- 状态栏 -->
    <TextBlock Text="All layout features working!" FontSize="14" PaddingTop="10" />
</StackPanel>
