@using EclipseUI.Controls
@using EclipseUI.Layout

<StackPanel PaddingLeft="30" PaddingTop="30" PaddingRight="30" PaddingBottom="30" Spacing="20">
    <!-- 标题 -->
    <TextBlock Text="🌑 EclipseUI - 尺寸属性测试" FontSize="24" />
    
    <!-- 固定尺寸测试 -->
    <TextBlock Text="📏 固定尺寸 (Width/Height)" FontSize="18" FontWeight="true" />
    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
        <Button Text="200x50" Width="200" Height="50" Background="#2196F3" />
        <Button Text="150x40" Width="150" Height="40" Background="#4CAF50" />
        <Button Text="100x30" Width="100" Height="30" Background="#FF9800" />
    </StackPanel>
    
    <!-- 最小尺寸测试 -->
    <TextBlock Text="📐 最小尺寸 (MinWidth)" FontSize="18" FontWeight="true" />
    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
        <Button Text="MinWidth=150" MinWidth="150" Background="#9C27B0" />
        <Button Text="MinWidth=200" MinWidth="200" Background="#673AB7" />
    </StackPanel>
    
    <!-- 最大尺寸测试 -->
    <TextBlock Text="📏 最大尺寸 (MaxWidth)" FontSize="18" FontWeight="true" />
    <StackPanel Spacing="10">
        <Button Text="MaxWidth=200" MaxWidth="200" Background="#FF5722" />
        <TextBlock Text="这个文本块设置了 MaxWidth=200，超过会自动换行显示更多内容！这是一个很长的文本用来测试换行效果。" MaxWidth="200" Background="#FFCCBC" PaddingLeft="10" PaddingTop="10" PaddingRight="10" PaddingBottom="10" />
    </StackPanel>
    
    <!-- 组合使用测试 -->
    <TextBlock Text="🔧 组合使用 (Min + Max)" FontSize="18" FontWeight="true" />
    <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
        <Button Text="Min100 Max300" MinWidth="100" MaxWidth="300" Background="#009688" />
        <Button Text="固定宽 200" Width="200" MinHeight="40" MaxHeight="60" Background="#00796B" />
    </StackPanel>
    
    <!-- 对比测试 -->
    <TextBlock Text="📊 对比测试" FontSize="18" FontWeight="true" />
    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *">
        <GridItem Row="0" Column="0" Background="#607D8B">
            <StackPanel PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
                <TextBlock Text="❌ 无限制" FontSize="16" FontWeight="true" PaddingBottom="10" />
                <Button Text="这个按钮没有设置宽度限制" Background="#546E7A" />
                <TextBlock Text="这个文本块也没有设置宽度限制" Background="#90A4AE" PaddingLeft="10" PaddingTop="10" PaddingRight="10" PaddingBottom="10" />
            </StackPanel>
        </GridItem>
        <GridItem Row="0" Column="1" Background="#37474F">
            <StackPanel PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
                <TextBlock Text="✅ MaxWidth=200" FontSize="16" FontWeight="true" PaddingBottom="10" />
                <Button Text="这个按钮设置了 MaxWidth=200" MaxWidth="200" Background="#263238" />
                <TextBlock Text="这个文本块设置了 MaxWidth=200，所以会换行显示！" MaxWidth="200" Background="#546E7A" PaddingLeft="10" PaddingTop="10" PaddingRight="10" PaddingBottom="10" />
            </StackPanel>
        </GridItem>
    </Grid>
    
    <!-- 状态栏 -->
    <TextBlock Text="✅ 已支持：Width/Height | MinWidth/MinHeight | MaxWidth/MaxHeight" FontSize="14" PaddingTop="20" />
</StackPanel>
