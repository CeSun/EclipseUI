@using EclipseUI.Controls
@using EclipseUI.Layout

<StackPanel PaddingLeft="30" PaddingTop="30" PaddingRight="30" PaddingBottom="30">
    <DockPanel>
        <!-- 顶部标题栏 - 蓝色背景 -->
        <DockPanelItem Dock="Dock.Top" Background="#2196F3">
            <StackPanel PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15">
                <TextBlock Text="🌑 EclipseUI - DockPanel 演示" FontSize="24" />
            </StackPanel>
        </DockPanelItem>
        
        <!-- 底部状态栏 - 灰色背景 -->
        <DockPanelItem Dock="Dock.Bottom" Background="#9E9E9E">
            <StackPanel PaddingLeft="20" PaddingTop="10" PaddingRight="20" PaddingBottom="10">
                <TextBlock Text="@($"状态：点击了 {_count} 次")" FontSize="14" />
            </StackPanel>
        </DockPanelItem>
        
        <!-- 左侧导航栏 - 绿色背景 -->
        <DockPanelItem Dock="Dock.Left" Background="#4CAF50">
            <StackPanel Orientation="StackOrientation.Vertical" Spacing="10" 
                        PaddingLeft="15" PaddingTop="20" PaddingRight="15" PaddingBottom="20">
                <Button Text="🏠 首页" OnClick="HandleHomeClick" />
                <Button Text="⚙️ 设置" OnClick="HandleSettingsClick" />
                <Button Text="ℹ️ 关于" OnClick="HandleAboutClick" />
            </StackPanel>
        </DockPanelItem>
        
        <!-- 右侧工具栏 - 橙色背景 -->
        <DockPanelItem Dock="Dock.Right" Background="#FF9800">
            <StackPanel Orientation="StackOrientation.Vertical" Spacing="10" 
                        PaddingLeft="15" PaddingTop="20" PaddingRight="15" PaddingBottom="20">
                <TextBlock Text="🛠️ 工具" FontSize="16" />
                <Button Text="📝 编辑" />
                <Button Text="🗑️ 删除" />
                <Button Text="💾 保存" />
            </StackPanel>
        </DockPanelItem>
        
        <!-- 中间主内容区 - 紫色背景（自动填充） -->
        <DockPanelItem Background="#9C27B0">
            <StackPanel Orientation="StackOrientation.Vertical" Spacing="15"
                        PaddingLeft="30" PaddingTop="30" PaddingRight="30" PaddingBottom="30">
                <TextBlock Text="欢迎使用 DockPanel 布局！" FontSize="28" />
                <TextBlock Text="这是一个五区域布局示例：&#10;• 顶部 - 标题栏（蓝色）&#10;• 底部 - 状态栏（灰色）&#10;• 左侧 - 导航栏（绿色）&#10;• 右侧 - 工具栏（橙色）&#10;• 中间 - 主内容区（紫色，自动填充）" FontSize="16" />
                <Button Text="点我 +1" Background="#4CAF50" FontSize="18" OnClick="HandleButtonClick" />
                <TextBlock Text="@($"当前计数：{_count}")" FontSize="20" FontWeight="true" Foreground="#FFFFFF" />
            </StackPanel>
        </DockPanelItem>
    </DockPanel>
</StackPanel>

@code {
    private int _count = 0;
    private string _currentPage = "首页";

    private async Task HandleButtonClick()
    {
        _count++;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleHomeClick()
    {
        _currentPage = "首页";
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSettingsClick()
    {
        _currentPage = "设置";
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleAboutClick()
    {
        _currentPage = "关于";
        await InvokeAsync(StateHasChanged);
    }
}
