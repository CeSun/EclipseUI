@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<ScrollView PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20">
    <StackPanel Spacing="15">
        <!-- 标题 -->
        <TextBlock Text="📝 TextBox 控件测试" FontSize="28" FontWeight="true" PaddingBottom="10" />
        
        <!-- ==================== 1. 基础 TextBox ==================== -->
        <TextBlock Text="🔤 1. 基础 TextBox" FontSize="18" FontWeight="true" Background="#E3F2FD" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox @bind-Text="@_basicText"  Placeholder="请输入文本..." Width="300" />
            <TextBlock Text="@($"当前值：{_basicText}")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== 2. 不同尺寸 ==================== -->
        <TextBlock Text="📏 2. 不同尺寸" FontSize="18" FontWeight="true" Background="#E8F5E9" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="宽度 200" Width="200" Placeholder="Width=200" />
            <TextBox Text="宽度 350" Width="350" Placeholder="Width=350" />
            <TextBox Text="高度 50" Height="50" Placeholder="Height=50" />
            <TextBox Text="宽 400 高 60" Width="400" Height="60" Placeholder="Width=400, Height=60" />
        </StackPanel>
        
        <!-- ==================== 3. 最小/最大尺寸 ==================== -->
        <TextBlock Text="📐 3. 最小/最大尺寸" FontSize="18" FontWeight="true" Background="#FFF3E0" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="MinWidth=150" MinWidth="150" Placeholder="最小宽度 150" />
            <TextBox Text="MaxWidth=250" MaxWidth="250" Placeholder="最大宽度 250" />
            <TextBox Text="MinHeight=50" MinHeight="50" Placeholder="最小高度 50" />
        </StackPanel>
        
        <!-- ==================== 4. 对齐方式 ==================== -->
        <TextBlock Text="📍 4. 对齐方式" FontSize="18" FontWeight="true" Background="#F3E5F5" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="左对齐" Width="300" HorizontalAlignment="HorizontalAlignment.Left" />
            <TextBox Text="居中对齐" Width="300" HorizontalAlignment="HorizontalAlignment.Center" />
            <TextBox Text="右对齐" Width="300" HorizontalAlignment="HorizontalAlignment.Right" />
            <TextBox Text="拉伸填满" HorizontalAlignment="HorizontalAlignment.Stretch" />
        </StackPanel>
        
        <!-- ==================== 5. 自定义样式 ==================== -->
        <TextBlock Text="🎨 5. 自定义样式" FontSize="18" FontWeight="true" Background="#FFEBEE" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="自定义背景色" Width="300" Background="#FFF9C4" Placeholder="黄色背景" />
            <TextBox Text="自定义前景色" Width="300" Foreground="#D32F2F" Placeholder="红色文字" />
            <TextBox Text="大字体" Width="300" FontSize="20" Placeholder="FontSize=20" />
            <TextBox Text="小字体" Width="300" FontSize="10" Placeholder="FontSize=10" />
        </StackPanel>
        
        <!-- ==================== 6. 内边距 ==================== -->
        <TextBlock Text="🔲 6. 内边距" FontSize="18" FontWeight="true" Background="#E0F7FA" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="默认内边距" Width="300" />
            <TextBox Text="大内边距" Width="300" PaddingLeft="20" PaddingTop="15" PaddingRight="20" PaddingBottom="15" />
            <TextBox Text="小内边距" Width="300" PaddingLeft="5" PaddingTop="3" PaddingRight="5" PaddingBottom="3" />
        </StackPanel>
        
        <!-- ==================== 7. 事件处理 ==================== -->
        <TextBlock Text="⚡ 7. 事件处理" FontSize="18" FontWeight="true" Background="#E8EAF6" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="@_eventText" TextChanged="OnEventTextChanged" OnFocus="OnFocus" OnBlur="OnBlur" Width="300" Placeholder="输入文本并观察下方日志" />
            <TextBlock Text="📋 事件日志:" FontSize="14" FontWeight="true" />
            <StackPanel Spacing="5">
                @foreach (var log in _eventLogs)
                {
                    <TextBlock Text="@log" FontSize="12" />
                }
            </StackPanel>
        </StackPanel>
        
        <!-- ==================== 8. 组合布局 ==================== -->
        <TextBlock Text="🔧 8. 组合布局" FontSize="18" FontWeight="true" Background="#FFF8E1" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="100, *" Spacing="10">
            <GridItem Row="0" Column="0" VerticalAlignment="VerticalAlignment.Center">
                <TextBlock Text="用户名:" FontSize="14" />
            </GridItem>
            <GridItem Row="0" Column="1">
                <TextBox Text="@_username" TextChanged="OnUsernameChanged" Placeholder="请输入用户名" />
            </GridItem>
            <GridItem Row="1" Column="0" VerticalAlignment="VerticalAlignment.Center">
                <TextBlock Text="密码:" FontSize="14" />
            </GridItem>
            <GridItem Row="1" Column="1">
                <TextBox Text="@_password" TextChanged="OnPasswordChanged" Placeholder="请输入密码" />
            </GridItem>
            <GridItem Row="2" Column="0" ColumnSpan="2">
                <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10">
                    <Button Text="登录" Width="100" Background="#2196F3" OnClick="OnLogin" />
                    <Button Text="取消" Width="100" Background="#9E9E9E" />
                </StackPanel>
            </GridItem>
        </Grid>
        
        <!-- ==================== 9. 中文和 Emoji 测试 ==================== -->
        <TextBlock Text="🌏 9. 中文和 Emoji 测试" FontSize="18" FontWeight="true" Background="#FCE4EC" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBox Text="@_chineseText" TextChanged="OnChineseTextChanged" Width="400" Placeholder="支持中文输入和 emoji 🎉🚀✨" />
            <TextBlock Text="@($"当前值：{_chineseText}")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== 状态栏 ==================== -->
        <TextBlock Text="✅ 已完整支持：文本输入 | 光标闪烁 | 文本选择 | 退格删除 | 方向键移动 | 占位符 | 焦点管理 | 事件回调 | 中文/Emoji" FontSize="13" Background="#ECEFF1" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="12" />
    </StackPanel>
</ScrollView>

@code {
    private string _basicText = "";
    private string _eventText = "";
    private string _username = "";
    private string _password = "";
    private string _chineseText = "";
    private List<string> _eventLogs = new();
    
    private void OnBasicTextChanged(string text)
    {
        _basicText = text;
    }
    
    private void OnEventTextChanged(string text)
    {
        _eventText = text;
    }
    
    private void OnFocus(FocusEventArgs e)
    {
        _eventLogs.Add($"[{DateTime.Now:HH:mm:ss}] 获得焦点");
        if (_eventLogs.Count > 5) _eventLogs.RemoveAt(0);
    }
    
    private void OnBlur(FocusEventArgs e)
    {
        _eventLogs.Add($"[{DateTime.Now:HH:mm:ss}] 失去焦点");
        if (_eventLogs.Count > 5) _eventLogs.RemoveAt(0);
    }
    
    private void OnUsernameChanged(string text)
    {
        _username = text;
    }
    
    private void OnPasswordChanged(string text)
    {
        _password = text;
    }
    
    private void OnLogin(MouseEventArgs e)
    {
        _eventLogs.Add($"[{DateTime.Now:HH:mm:ss}] 点击登录 - 用户：{_username}");
        if (_eventLogs.Count > 5) _eventLogs.RemoveAt(0);
    }
    
    private void OnChineseTextChanged(string text)
    {
        _chineseText = text;
    }
}
