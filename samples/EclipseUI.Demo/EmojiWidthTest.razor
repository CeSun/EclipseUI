@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel Padding="20" Spacing="15">
    <TextBlock Text="Emoji 宽度调试" FontSize="20" FontWeight="true" PaddingBottom="10" />
    
    <!-- ⬆️ 带变体选择器 -->
    <TextBlock Text="⬆️ 向上箭头 (带变体选择器 U+FE0F)" FontSize="18" Background="#E3F2FD" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    
    <!-- ⬆ 不带变体选择器 -->
    <TextBlock Text="⬆ 向上箭头 (无变体选择器)" FontSize="18" Background="#E8F5E9" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    
    <!-- 📌 普通 emoji -->
    <TextBlock Text="📌 图钉 (U+1F4CC)" FontSize="18" Background="#FFF3E0" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    
    <!-- ↖ 对角箭头 -->
    <TextBlock Text="↖ 左上箭头 (U+2196)" FontSize="18" Background="#F3E5F5" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    
    <!-- 对比：纯文字 -->
    <TextBlock Text="5. 垂直对齐 (纯文字)" FontSize="18" Background="#E0F2F1" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
</StackPanel>
