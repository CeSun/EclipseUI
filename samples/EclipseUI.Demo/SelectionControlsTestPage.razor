@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<ScrollView PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20">
    <StackPanel Spacing="20">
        <!-- 标题 -->
        <TextBlock Text="📋 选择控件测试页面" FontSize="28" FontWeight="true" PaddingBottom="10" />
        
        <!-- ==================== ComboBox ==================== -->
        <TextBlock Text="🔽 ComboBox - 下拉选择框" FontSize="20" FontWeight="true" Background="#E3F2FD" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <ComboBox ItemsSource="@_comboBoxItems" 
                      SelectedItem="@_selectedItem" 
                      SelectedItemChanged="OnSelectedItemChanged"
                      Placeholder="请选择一个选项..."
                      Width="250" />
            <TextBlock Text="@($"当前选择：{_selectedItem ?? "无"}")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== CheckBox ==================== -->
        <TextBlock Text="☑️ CheckBox - 复选框" FontSize="20" FontWeight="true" Background="#E8F5E9" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <CheckBox Content="同意服务条款" IsChecked="@_agreeToTerms" IsCheckedChanged="OnAgreeToTermsChanged" />
            <CheckBox Content="订阅新闻邮件" IsChecked="@_subscribeNewsletter" IsCheckedChanged="OnSubscribeChanged" />
            <CheckBox Content="不确定状态（三态）" IsChecked="@_threeState" IsThreeState="true" IsCheckedChanged="OnThreeStateChanged" />
            <TextBlock Text="@($"同意条款：{_agreeToTerms} | 订阅：{_subscribeNewsletter} | 三态：{_threeState})")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== RadioButton ==================== -->
        <TextBlock Text="🔘 RadioButton - 单选框" FontSize="20" FontWeight="true" Background="#FFF3E0" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="10">
            <TextBlock Text="选择支付方式：" FontSize="14" />
            <RadioButton Content="💳 信用卡" GroupName="Payment" IsChecked="@_isCreditCard" IsCheckedChanged="OnPaymentChanged" />
            <RadioButton Content="🏦 银行转账" GroupName="Payment" IsChecked="@_isBankTransfer" IsCheckedChanged="OnPaymentChanged" />
            <RadioButton Content="💰 支付宝" GroupName="Payment" IsChecked="@_isAlipay" IsCheckedChanged="OnPaymentChanged" />
            <RadioButton Content="💵 微信支付" GroupName="Payment" IsChecked="@_isWeChatPay" IsCheckedChanged="OnPaymentChanged" />
            <TextBlock Text="@($"当前选择：{_selectedPayment}")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== ToggleSwitch ==================== -->
        <TextBlock Text="🔛 ToggleSwitch - 开关" FontSize="20" FontWeight="true" Background="#F3E5F5" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="15">
            <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10">
                <ToggleSwitch IsOn="@_wifiEnabled" IsOnChanged="OnWifiChanged" />
                <TextBlock Text="Wi-Fi" FontSize="14" VerticalAlignment="VerticalAlignment.Center" />
            </StackPanel>
            <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10">
                <ToggleSwitch IsOn="@_bluetoothEnabled" IsOnChanged="OnBluetoothChanged" OnColor="#4CAF50" OffColor="#9E9E9E" />
                <TextBlock Text="蓝牙" FontSize="14" VerticalAlignment="VerticalAlignment.Center" />
            </StackPanel>
            <StackPanel Orientation="StackOrientation.Horizontal" Spacing="10">
                <ToggleSwitch IsOn="@_airplaneMode" IsOnChanged="OnAirplaneChanged" OnColor="#F44336" />
                <TextBlock Text="飞行模式" FontSize="14" VerticalAlignment="VerticalAlignment.Center" />
            </StackPanel>
            <TextBlock Text="@($"Wi-Fi: {_wifiEnabled} | 蓝牙：{_bluetoothEnabled} | 飞行模式：{_airplaneMode}")" FontSize="14" />
        </StackPanel>
        
        <!-- ==================== Slider ==================== -->
        <TextBlock Text="📊 Slider - 滑块" FontSize="20" FontWeight="true" Background="#E0F7FA" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <StackPanel Spacing="20">
            <!-- 水平滑块 -->
            <StackPanel>
                <TextBlock Text="音量控制" FontSize="14" PaddingBottom="5" />
                <Slider Value="@_volume" ValueChanged="OnVolumeChanged" Minimum="0" Maximum="100" Width="400" />
                <TextBlock Text="@($"音量：{_volume}")" FontSize="12" />
            </StackPanel>
            
            <!-- 亮度滑块 -->
            <StackPanel>
                <TextBlock Text="亮度" FontSize="14" PaddingBottom="5" />
                <Slider Value="@_brightness" ValueChanged="OnBrightnessChanged" Minimum="0" Maximum="100" Width="400" ShowTicks="true" TickFrequency="10" IsSnapToTick="true" />
                <TextBlock Text="@($"亮度：{_brightness} (带刻度，吸附)")" FontSize="12" />
            </StackPanel>
            
            <!-- 垂直滑块 -->
            <StackPanel Orientation="StackOrientation.Horizontal" Spacing="30">
                <StackPanel>
                    <TextBlock Text="垂直滑块" FontSize="14" PaddingBottom="5" HorizontalAlignment="HorizontalAlignment.Center" />
                    <Slider Value="@_verticalValue" ValueChanged="OnVerticalChanged" Minimum="0" Maximum="100" Height="200" Orientation="Orientation.Vertical" />
                    <TextBlock Text="@($"值：{_verticalValue}")" FontSize="12" HorizontalAlignment="HorizontalAlignment.Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
        
        <!-- ==================== 组合示例 ==================== -->
        <TextBlock Text="🔧 组合示例 - 设置面板" FontSize="20" FontWeight="true" Background="#FFF8E1" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" HorizontalAlignment="HorizontalAlignment.Stretch" />
        <Grid ColumnDefinitions="200, *" RowDefinitions="Auto, Auto, Auto, Auto" Spacing="10" Background="#FAFAFA" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="15">
            <GridItem Row="0" Column="0" VerticalAlignment="VerticalAlignment.Center"><TextBlock Text="通知频率：" FontSize="14" /></GridItem>
            <GridItem Row="0" Column="1"><ComboBox ItemsSource="@_notificationOptions" SelectedItem="@_selectedNotification" SelectedItemChanged="OnNotificationChanged" Width="200" /></GridItem>
            
            <GridItem Row="1" Column="0" VerticalAlignment="VerticalAlignment.Center"><TextBlock Text="启用推送：" FontSize="14" /></GridItem>
            <GridItem Row="1" Column="1"><ToggleSwitch IsOn="@_pushEnabled" IsOnChanged="OnPushChanged" /></GridItem>
            
            <GridItem Row="2" Column="0" VerticalAlignment="VerticalAlignment.Center"><TextBlock Text="提醒音量：" FontSize="14" /></GridItem>
            <GridItem Row="2" Column="1"><Slider Value="@_alertVolume" ValueChanged="OnAlertVolumeChanged" Minimum="0" Maximum="100" Width="300" /></GridItem>
            
            <GridItem Row="3" Column="0" VerticalAlignment="VerticalAlignment.Center"><TextBlock Text="提醒方式：" FontSize="14" /></GridItem>
            <GridItem Row="3" Column="1">
                <StackPanel Orientation="StackOrientation.Horizontal" Spacing="15">
                    <CheckBox Content="声音" IsChecked="@_alertSound" IsCheckedChanged="OnAlertSoundChanged" />
                    <CheckBox Content="震动" IsChecked="@_alertVibrate" IsCheckedChanged="OnAlertVibrateChanged" />
                    <CheckBox Content="闪光灯" IsChecked="@_alertFlash" IsCheckedChanged="OnAlertFlashChanged" />
                </StackPanel>
            </GridItem>
        </Grid>
        
        <!-- 状态栏 -->
        <TextBlock Text="✅ 已实现：ComboBox | CheckBox（三态） | RadioButton（分组互斥） | ToggleSwitch | Slider（水平/垂直/刻度）" FontSize="13" Background="#ECEFF1" PaddingLeft="15" PaddingTop="15" PaddingRight="15" PaddingBottom="12" />
    </StackPanel>
</ScrollView>

@code {
    // ComboBox
    private List<string> _comboBoxItems = new() { "选项一", "选项二", "选项三", "选项四", "选项五" };
    private string? _selectedItem;
    
    // CheckBox
    private bool? _agreeToTerms = false;
    private bool? _subscribeNewsletter = false;
    private bool? _threeState = null;
    
    // RadioButton
    private bool? _isCreditCard = true;
    private bool? _isBankTransfer = false;
    private bool? _isAlipay = false;
    private bool? _isWeChatPay = false;
    private string _selectedPayment = "信用卡";
    
    // ToggleSwitch
    private bool _wifiEnabled = true;
    private bool _bluetoothEnabled = false;
    private bool _airplaneMode = false;
    
    // Slider
    private double _volume = 50;
    private double _brightness = 75;
    private double _verticalValue = 50;
    
    // 组合示例
    private List<string> _notificationOptions = new() { "实时", "每小时", "每天", "每周" };
    private string? _selectedNotification = "实时";
    private bool _pushEnabled = true;
    private double _alertVolume = 50;
    private bool? _alertSound = true;
    private bool? _alertVibrate = false;
    private bool? _alertFlash = false;
    
    private void OnSelectedItemChanged(string? item) => _selectedItem = item;
    private void OnAgreeToTermsChanged(bool? v) => _agreeToTerms = v;
    private void OnSubscribeChanged(bool? v) => _subscribeNewsletter = v;
    private void OnThreeStateChanged(bool? v) => _threeState = v;
    
    private void OnPaymentChanged(bool? v)
    {
        if (v == true)
        {
            if (_isCreditCard == true) _selectedPayment = "信用卡";
            else if (_isBankTransfer == true) _selectedPayment = "银行转账";
            else if (_isAlipay == true) _selectedPayment = "支付宝";
            else if (_isWeChatPay == true) _selectedPayment = "微信支付";
        }
    }
    
    private void OnWifiChanged(bool v) => _wifiEnabled = v;
    private void OnBluetoothChanged(bool v) => _bluetoothEnabled = v;
    private void OnAirplaneChanged(bool v) => _airplaneMode = v;
    
    private void OnVolumeChanged(double v) => _volume = v;
    private void OnBrightnessChanged(double v) => _brightness = v;
    private void OnVerticalChanged(double v) => _verticalValue = v;
    
    private void OnNotificationChanged(string? v) => _selectedNotification = v;
    private void OnPushChanged(bool v) => _pushEnabled = v;
    private void OnAlertVolumeChanged(double v) => _alertVolume = v;
    private void OnAlertSoundChanged(bool? v) => _alertSound = v;
    private void OnAlertVibrateChanged(bool? v) => _alertVibrate = v;
    private void OnAlertFlashChanged(bool? v) => _alertFlash = v;
}
