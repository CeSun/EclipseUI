@using EclipseUI.Controls
@using EclipseUI.Layout
@using EclipseUI.Core

<StackPanel PaddingLeft="20" PaddingTop="20" PaddingRight="20" PaddingBottom="20" Spacing="20">
    <TextBlock Text="Grid 列宽测试" FontSize="24" FontWeight="true" PaddingBottom="10" />
    
    <!-- 4 列等宽测试 -->
    <TextBlock Text="4 列等宽 (*, *, *, *)" FontSize="18" Background="#E3F2FD" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    <Grid RowDefinitions="60, 60" ColumnDefinitions="*, *, *, *" Spacing="5" Background="#FFF0F0">
        <GridItem Row="0" Column="0" Background="#F44336"><TextBlock Text="列 1" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="0" Column="1" Background="#4CAF50"><TextBlock Text="列 2" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="0" Column="2" Background="#FFC107"><TextBlock Text="列 3" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="0" Column="3" Background="#2196F3"><TextBlock Text="列 4" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="1" Column="0" Background="#9C27B0"><TextBlock Text="60px" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="1" Column="1" Background="#00BCD4"><TextBlock Text="60px" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="1" Column="2" Background="#FF5722"><TextBlock Text="60px" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
        <GridItem Row="1" Column="3" Background="#795548"><TextBlock Text="60px" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" /></GridItem>
    </Grid>
    
    <!-- 2 列等宽测试 -->
    <TextBlock Text="2 列等宽 (*, *)" FontSize="18" Background="#E8F5E9" PaddingLeft="10" PaddingTop="8" PaddingRight="10" PaddingBottom="8" />
    <Grid ColumnDefinitions="*, *" Spacing="15" Background="#F0F0FF">
        <GridItem Column="0" Background="#3F51B5"><TextBlock Text="左列 50%" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Padding="20" /></GridItem>
        <GridItem Column="1" Background="#4CAF50"><TextBlock Text="右列 50%" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Padding="20" /></GridItem>
    </Grid>
</StackPanel>
